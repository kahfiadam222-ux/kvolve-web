# --- Supabase (W-FR-1.1 OAuth & Auth System) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server kolaborasi Y.js (W-FR-2.2 Multiplayer Cursor) ---
# Dev lokal : ws://localhost:1234   (jalankan: npm run collab:dev)
# Produksi  : WAJIB wss:// (TLS) sesuai NFR keamanan transfer data.
# Kosongkan variabel ini untuk menjalankan kanvas dalam mode offline (tanpa kolaborasi).
NEXT_PUBLIC_COLLAB_WS_URL=ws://localhost:1234
